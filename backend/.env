APP_NAME=HiBuddy
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-me-in-production-use-a-strong-random-secret-key-at-least-32-bytes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

DATABASE_URL=postgresql+asyncpg://hibuddy:hibuddy_secret@localhost:5432/hibuddy
DATABASE_URL_SYNC=postgresql://hibuddy:hibuddy_secret@localhost:5432/hibuddy

REDIS_URL=redis://localhost:6379/0

MILVUS_HOST=localhost
MILVUS_PORT=19530

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hibuddy
MINIO_SECURE=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

CORS_ORIGINS=["*"]

SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

SWIPE_DAILY_LIKE_LIMIT=50
SWIPE_DAILY_SUPERLIKE_LIMIT=3
PASS_COOLDOWN_DAYS=7
MAX_ACTIVE_PROJECTS_PER_OWNER=3
CHECKOUT_REVIEW_HOURS=72
GRACE_PERIOD_HOURS=12
MAX_COURSE_SUGGESTIONS=5
