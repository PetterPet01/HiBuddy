APP_NAME=HiBuddy
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=replace-with-at-least-32-random-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_SHORT_DAYS=1

DATABASE_URL=postgresql+asyncpg://hibuddy:hibuddy_secret@localhost:5433/hibuddy
DATABASE_URL_SYNC=postgresql://hibuddy:hibuddy_secret@localhost:5433/hibuddy
REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hibuddy
MINIO_SECURE=false
MEDIA_PUBLIC_BASE_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

CORS_ORIGINS=["http://localhost:3000"]

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@hibuddy.local
SMTP_USE_TLS=true
AUTH_CODE_TTL_MINUTES=15
AUTH_CODE_RESEND_SECONDS=60
AUTH_CODE_MAX_ATTEMPTS=5

MILVUS_HOST=localhost
MILVUS_PORT=19530
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
ENABLE_EMBEDDINGS=false
ENABLE_MILVUS=false
MILVUS_CONNECT_TIMEOUT_SECONDS=0.5

SWIPE_DAILY_LIKE_LIMIT=50
SWIPE_DAILY_SUPERLIKE_LIMIT=3
PASS_COOLDOWN_DAYS=7
MAX_ACTIVE_PROJECTS_PER_OWNER=3
CHECKOUT_REVIEW_HOURS=72
GRACE_PERIOD_HOURS=12
MAX_COURSE_SUGGESTIONS=5

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-medium-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1
